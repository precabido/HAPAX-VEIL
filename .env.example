# Compose project name (optional)
PROJECT_NAME=hapax-veil

# Public origin used by your reverse proxy and users
DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost:8080

# PostgreSQL
POSTGRES_DB=hapax
POSTGRES_USER=hapax
POSTGRES_PASSWORD=change-me-postgres-password

# Internal nginx listener published by Docker Compose
# Keep 127.0.0.1 when another reverse proxy/TLS terminator fronts the service.
NGINX_BIND_IP=127.0.0.1
NGINX_HTTP_PORT=8080

# Optional backend tuning
PGPOOL_MAX=10
CLEANUP_INTERVAL_MS=60000
CLEANUP_FIRST_DELAY_MS=15000
